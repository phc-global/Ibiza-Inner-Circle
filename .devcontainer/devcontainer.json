{
  "name": "Ibiza Inner Circle - Samar Brain",

  "// note": "prebuilt image — Node, Python, tools, media/audio deps AND Claude Code are baked in. Nothing installs at runtime.",
  "image": "ghcr.io/phc-global/ibiza-inner-circle:latest",

  "containerEnv": { "BRAIN_URL": "http://159.65.254.94:8080" },

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "workbench.startupEditor": "readme",
        "remote.autoForwardPorts": true
      },
      "extensions": [
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "bradlc.vscode-tailwindcss",
        "formulahendry.auto-rename-tag",
        "christian-kohler.path-intellisense",
        "pkief.material-icon-theme"
      ]
    }
  },

  "forwardPorts": [3000, 3001, 4000, 5000, 5173, 8000, 8080],
  "portsAttributes": {
    "3000": { "label": "Preview", "onAutoForward": "openPreview", "visibility": "public" },
    "5173": { "label": "Vite Preview", "onAutoForward": "openPreview", "visibility": "public" },
    "8000": { "label": "Python Server", "onAutoForward": "notify", "visibility": "public" }
  },

  "postCreateCommand": "npm install --no-fund --no-audit || true",
  "postStartCommand": "bash .devcontainer/seed-claude-auth.sh; echo '✅ Ready — Node, Python & tools are already here. Type: claude   (need ffmpeg/audio for /voice? run: bash .devcontainer/install-extras.sh)'"
}
